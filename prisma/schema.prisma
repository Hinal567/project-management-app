generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  status      String
  priority    String
  dueDate     DateTime
  progress    Int

  tasks Task[]
}

model Task {
  id        Int      @id @default(autoincrement())
  title     String
  status    String
  priority  String
  dueDate   DateTime

  projectId Int?
  project   Project? @relation(fields: [projectId], references: [id])
}

model User {
  id        Int      @id @default(autoincrement())
  fullName  String
  email     String   @unique
  password  String
  role      String   @default("Project Manager")

  emailNotifications Boolean @default(true)
  taskReminders      Boolean @default(true)
  theme              String  @default("Light")

  createdAt DateTime @default(now())
}
